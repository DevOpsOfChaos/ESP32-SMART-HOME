# ============================================================
# SmartHome Server – Umgebungsvariablen (Beispiel)
# ============================================================
# Öffentliche Vorlage.
# Lokale .env daraus erzeugen und mit echten Werten befüllen.
# Die .env-Datei niemals committen (.gitignore).
# ============================================================

# MQTT-Broker
MQTT_HOST=127.0.0.1
MQTT_PORT=1883
MQTT_USER=mqtt_user
MQTT_PASSWORD=BITTE_AENDERN_STARKES_PASSWORT

# Node-RED
NODERED_PORT=1880

# Zeitzone für Node-RED und Automationen (TZ-Datenbankname)
TZ=Europe/Berlin

# Datenbankpfad für SQLite (optional, falls Datenhaltung genutzt)
SQLITE_PATH=/data/smarthome.sqlite

# InfluxDB (optional, zunächst deaktiviert)
INFLUX_ENABLED=false
INFLUX_URL=http://127.0.0.1:8086
INFLUX_TOKEN=BITTE_AENDERN_INFLUX_TOKEN
INFLUX_ORG=smarthome
INFLUX_BUCKET=smarthome
